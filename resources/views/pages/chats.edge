<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Chats</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script type="module">
      import { Transmit } from 'https://cdn.jsdelivr.net/npm/@adonisjs/transmit-client@1.1.0/build/index.js'
      window.Transmit = Transmit
    </script>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>

  <body class="chat-page-body">
    <!-- Top red header -->
    <header class="chat-header">
      <button class="icon-button" id="chatBackButton">
        <img src="/images/left.png" alt="Back" width="24" height="24" />
      </button>



      <button class="icon-button">
        <img src="/images/notification-bell.png" alt="Notifications" width="24" height="24" />
      </button>
    </header>

    <!-- 2-column chat layout -->
    <div class="chat-shell">
      <!-- Left: list of conversations -->
      <aside class="chat-list">
        <h2 class="chat-list-title">Chats</h2>
        <div class="chat-search-bar">
          <span class="search-icon">🔍</span>
          <input type="text" placeholder="Search..." />
        </div>
        <button class="new-chat-btn" id="newChatBtn">+ New Chat</button>

        <div class="chat-list-items">
          <!-- dummy chats -->
          <button class="chat-list-item is-active">
            <div class="chat-avatar-circle"></div>
            <div class="chat-list-text">
              <div class="chat-list-name">Display name</div>
              <div class="chat-list-last">Last message preview…</div>
            </div>
          </button>

          <button class="chat-list-item">
            <div class="chat-avatar-circle"></div>
            <div class="chat-list-text">
              <div class="chat-list-name">Another user</div>
              <div class="chat-list-last">Last message preview…</div>
            </div>
          </button>

          <!-- add more dummy items if needed -->
        </div>
      </aside>

      <!-- Right: conversation -->
      <section class="chat-main">
        <!-- empty state (shown before any chat is selected) -->
        <div class="chat-empty-state" id="chatEmptyState">
          <p>Select a conversation to start chatting</p>
        </div>

        <!-- chat view (hidden until a chat is selected) -->
        <div id="chatView" style="display:none; flex-direction:column; height:100%;">
          <header class="chat-main-header">
            <div class="chat-main-user">
              <div class="chat-avatar-circle" id="chatHeaderAvatar"></div>
              <span class="chat-main-name" id="chatHeaderName"></span>
            </div>
            <div class="chat-main-status"></div>
          </header>

          <div class="chat-messages" id="chatMessages"></div>

          <form class="chat-input-bar" id="chatForm">
            <input type="text" placeholder="Type a message..." autocomplete="off" />
            <button type="submit" class="chat-send-button">
              <img src="/images/send.png" alt="Send" width="24" height="24" />
            </button>
          </form>
        </div>
      </section>
    </div>

    <!-- New Chat Modal -->
    <div class="modal-overlay" id="newChatOverlay" style="display:none;">
      <div class="modal-box">
        <div class="modal-header">
          <h3 class="modal-title">New Chat</h3>
          <button class="modal-close" id="newChatClose">&times;</button>
        </div>

        <input type="text" class="modal-search-input" id="userSearchInput" placeholder="Search users..." autocomplete="off" />

        <div class="modal-search-results" id="userSearchResults"></div>

        <div class="modal-selected" id="selectedUsers" style="display:none;">
          <p class="modal-selected-label" id="chatTypeLabel"></p>
          <div class="modal-selected-chips" id="selectedChips"></div>
        </div>

        <button class="modal-start-btn" id="startChatBtn" style="display:none;">Start Chat</button>
      </div>
    </div>

    <script src="/js/script_chats.js"></script>
  </body>
</html>
